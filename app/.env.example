# ── UniEvent Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PredictHQ API key
# Get your free key at: https://control.predicthq.com/
PREDICTHQ_API_KEY=your_predicthq_api_key_here

# AWS S3 Bucket name (must already exist)
S3_BUCKET_NAME=unievents-media-youruniquename

# AWS Region
AWS_REGION=us-east-1

# Flask secret key (change to a strong random string)
SECRET_KEY=change-this-to-a-random-secret-string
